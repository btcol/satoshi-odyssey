# Configuración del Entorno de Nodos Lightning y Bitcoin
# Edita este archivo para ajustar los valores a tu entorno.

# Red a utilizar (ej: testnet4, mainnet, signet)
NETWORK=testnet4

# Binario de LNCLI
LNCLI_BIN=/usr/local/bin/lncli

# Binario de Bitcoin CLI
BITCOIN_CLI_BIN=/usr/local/bin/bitcoin-cli

# ── Configuración del servidor web ─────────────────────────
# Usuario y contraseña para acceder al dashboard web
WEB_USER=satoshi
WEB_PASS=lightning

# Puerto en el que escucha el servidor
WEB_PORT=9630

# Interfaz de red (0.0.0.0 = todas, 127.0.0.1 = solo local)
WEB_HOST=0.0.0.0
